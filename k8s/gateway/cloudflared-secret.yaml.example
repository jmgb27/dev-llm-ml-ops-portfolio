# Copy to cloudflared-secret.yaml (gitignored) OR use scripts/apply-cloudflared-secret.sh
# with CLOUDFLARE_TUNNEL_TOKEN in .env — do not commit real tokens.
#
# Create tunnel: https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/get-started/create-remote-tunnel/
apiVersion: v1
kind: Secret
metadata:
  name: cloudflared-credentials
  namespace: llm-gateway
  labels:
    app: cloudflared
type: Opaque
stringData:
  tunnel-token: "REPLACE_WITH_CLOUDFLARE_TUNNEL_TOKEN"
