# Reference only — live Application is rendered by ansible/deploy-argocd.yml
# (ansible/templates/argocd-application.yaml.j2) with container_registry from
# ansible/group_vars/secrets.yml (gitignored).
#
# Do not kubectl apply this file directly unless you add the kustomize.images
# override for your private registry host.
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: llm-gateway
  namespace: argocd
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  source:
    repoURL: https://github.com/jmgb27/devops_llmops_mlops_portfolio.git
    targetRevision: master
    path: k8s
  destination:
    server: https://kubernetes.default.svc
    namespace: llm-gateway
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=false
