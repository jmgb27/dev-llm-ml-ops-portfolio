        {
          "expr": "llamacpp:predicted_tokens_seconds",
          "legendFormat": "generation tokens/sec",
          "refId": "A"
        }
      ],
      "title": "LLM Token Generation Speed",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 4 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "llamacpp:requests_processing",
          "legendFormat": "processing",
          "refId": "A"
        },
        {
          "expr": "llamacpp:requests_deferred",
          "legendFormat": "deferred",
          "refId": "B"
        }
      ],
      "title": "Inference Slots (processing / deferred)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(litellm_proxy_total_requests_metric_total[1m]))",
          "legendFormat": "gateway requests/sec",
          "refId": "A"
        }
      ],
      "title": "LiteLLM Gateway Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(litellm_proxy_failed_requests_metric_total[1m]))",
          "legendFormat": "failed requests/sec",
          "refId": "A"
        }
      ],
      "title": "LiteLLM Failed Requests (incl. 429)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(litellm_request_total_latency_metric_bucket[5m])) by (le))",
          "legendFormat": "p95 total latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(litellm_llm_api_latency_metric_bucket[5m])) by (le))",
          "legendFormat": "p95 llm api latency",
          "refId": "B"
        }
