      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "targets": [
        {
          "expr": "litellm_in_flight_requests",
          "legendFormat": "in-flight",
          "refId": "A"
        },
        {
          "expr": "redis_connected_clients",
          "legendFormat": "redis clients",
          "refId": "B"
        }
      ],
      "title": "Queue Depth Signals",
      "type": "timeseries"
    }
