# Host port exposed for the llama.cpp inference API
HOST_PORT=8080

# GGUF model file inside ./models (mounted read-only at /models)
MODEL_FILE=Llama-3.2-1B-Instruct-Q4_K_M.gguf

# Context window size (tokens)
CONTEXT_SIZE=4096

# Max concurrent inference slots
PARALLEL=4

# LiteLLM API gateway port (OpenAI-compatible /chat/completions)
LITELLM_PORT=4000

# API key clients send to LiteLLM (Authorization: Bearer sk-1234)
LITELLM_MASTER_KEY=sk-1234

# Redis (LiteLLM response cache + request queue state)
REDIS_PORT=6379

# How long queued requests wait for a free inference slot (seconds)
LITELLM_GLOBAL_MAX_PARALLEL_REQUEST_RETRY_TIMEOUT=120
# Max queue wait attempts before returning 429
LITELLM_GLOBAL_MAX_PARALLEL_REQUEST_RETRIES=10

# Gateway perimeter rate limits (litellm_config.yaml: rpm/tpm + enforce_model_rate_limits)
# Defaults: 60 requests/min, 80k tokens/min — edit litellm_config.yaml to tune

# Chat UI (FastAPI proxy + static frontend)
CHAT_UI_PORT=8000

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Cloudflare Tunnel (cluster only — never commit; apply via scripts/apply-cloudflared-secret.sh)
# CLOUDFLARE_TUNNEL_TOKEN=eyJ...

# Private container registry (never commit host or credentials)
# REGISTRY=your-registry.example.com
# REGISTRY_USERNAME=your-user
# REGISTRY_PASSWORD=your-token
